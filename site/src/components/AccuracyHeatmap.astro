---
/**
 * Per-state accuracy heatmap for a prediction engine.
 *
 * Rigorous-stats design:
 *   - Rows = states (sorted by n desc), columns = caller-defined metrics
 *   - Each metric column declares: key, label, kind (pct|num), and how
 *     to extract from the row
 *   - Cell color encodes the percentage-tier; cell text is the raw value
 *   - States with n < 5 flagged in italic (low statistical power)
 *   - Footer note states the metric definitions explicitly
 *
 * Designed for reuse across attribution, doctrine, and pillar engines
 * which all expose per-state hit@K counts but differ on the
 * ranking-quality metric (MRR vs mAP).
 */
interface MetricCol<R = Record<string, number>> {
  key: string;
  label: string;
  kind: 'pct' | 'num';
  /** Extractor from row → numeric value. For `pct` kind, returns 0–100 directly. */
  get: (row: R & { scored: number }) => number;
}
interface BaseRow {
  state: string;
  scored: number;
  [key: string]: number | string;
}
interface Props {
  rows: BaseRow[];
  metrics: MetricCol[];
  /** State id → display label. */
  labelOf?: (state: string) => string;
  /** Engine name for the caption. */
  engineLabel?: string;
  /** Optional footer description (e.g., "Doctrine pred. is multi-label..."). */
  footnote?: string;
}
const {
  rows,
  metrics,
  labelOf = (s: string) => s.toUpperCase(),
  engineLabel = 'engine',
  footnote,
} = Astro.props;

const sorted = [...rows].sort((a, b) => b.scored - a.scored);

function color(p: number): string {
  if (p >= 80) return 'color-mix(in srgb, var(--ctp-green) 70%, transparent)';
  if (p >= 60) return 'color-mix(in srgb, var(--ctp-green) 45%, var(--ctp-yellow) 25%)';
  if (p >= 40) return 'color-mix(in srgb, var(--ctp-yellow) 50%, transparent)';
  if (p >= 20) return 'color-mix(in srgb, var(--ctp-peach) 55%, transparent)';
  return 'color-mix(in srgb, var(--ctp-red) 50%, transparent)';
}
function textOn(p: number): string {
  return p >= 60 || p < 20 ? 'var(--ctp-base)' : 'var(--ctp-text)';
}

// Weighted-by-n totals for the pct metrics, for the caption
const totalN = sorted.reduce((s, r) => s + r.scored, 0);
const weightedTotals: Array<{ label: string; val: number }> = metrics
  .filter((m: MetricCol) => m.kind === 'pct')
  .map((m: MetricCol) => {
    const total = sorted.reduce((s, r) => s + m.get(r as never), 0);
    return { label: m.label, val: totalN > 0 ? (total / totalN) : 0 };
  });
---
<figure class="ah-figure">
  <figcaption class="ah-cap">
    Per-state accuracy of the {engineLabel}, leave-one-out CV.
    Colored cells show <strong>%</strong>; uncolored numeric columns
    show the metric value directly. Rows below n=5 (italic) carry
    low statistical power.
    {weightedTotals.length > 0 && (
      <> Weighted-by-n totals:{' '}
        {weightedTotals.map((t: { label: string; val: number }, i: number) => (
          <>{i > 0 && ', '}{t.label} {(t.val * 100).toFixed(1)}%</>
        ))}.
      </>
    )}
    {footnote && <><br/><span class="ah-cap-meta">{footnote}</span></>}
  </figcaption>

  <table class="ah-table">
    <thead>
      <tr>
        <th class="ah-th-state">state</th>
        <th class="ah-th-n">n</th>
        {metrics.map((m: MetricCol) => <th>{m.label}</th>)}
      </tr>
    </thead>
    <tbody>
      {sorted.map((r) => {
        const lowN = r.scored < 5;
        return (
          <tr class={lowN ? 'ah-row ah-low-n' : 'ah-row'}>
            <td class="ah-cell-state">{labelOf(r.state)}</td>
            <td class="ah-cell-n">{r.scored}</td>
            {metrics.map((m: MetricCol) => {
              if (m.kind === 'pct') {
                const v = m.get(r as never);
                const p = r.scored > 0 ? (v / r.scored) * 100 : 0;
                return (
                  <td class="ah-cell" style={`background: ${color(p)}; color: ${textOn(p)};`}>{p.toFixed(1)}</td>
                );
              } else {
                const v = m.get(r as never);
                return <td class="ah-cell ah-num">{v.toFixed(3)}</td>;
              }
            })}
          </tr>
        );
      })}
    </tbody>
  </table>
</figure>

<style>
  .ah-figure {
    margin: 0;
    background: var(--ctp-mantle);
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    padding: 0.875rem 1rem 1rem;
  }
  .ah-cap {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-subtext0);
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }
  .ah-cap strong { color: var(--ctp-text); }
  .ah-cap-meta { color: var(--ctp-overlay1); font-size: 0.6875rem; }
  .ah-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 1px;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }
  .ah-table th {
    background: var(--ctp-base);
    color: var(--ctp-overlay1);
    font-weight: 600;
    padding: 0.375rem 0.5rem;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
  }
  .ah-th-state { text-align: left; }
  .ah-th-n { text-align: right; }
  .ah-row td { padding: 0.3rem 0.5rem; }
  .ah-cell-state { color: var(--ctp-text); }
  .ah-cell-n { text-align: right; color: var(--ctp-subtext0); }
  .ah-cell { text-align: center; }
  .ah-num { background: var(--ctp-base); color: var(--ctp-text); }
  .ah-low-n .ah-cell-state, .ah-low-n .ah-cell-n {
    font-style: italic;
    opacity: 0.7;
  }
</style>
