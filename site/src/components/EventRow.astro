---
import FlagChip from './FlagChip.astro';
import { eventStateId, atlas, type AuspexEvent } from '../utils/atlas';

interface Props {
  event: AuspexEvent;
}
const { event } = Astro.props;
const state = eventStateId(event, atlas());
const date = event.start_date ?? event.disclosure_date ?? '';
const types = event.incident_type ?? [];
---
<a class="event-row" href={`/event/${event.id}`}>
  <span class="event-row-date">{date}</span>
  <FlagChip state={state} small />
  <span class="event-row-name">{event.name}</span>
  {types.length > 0 && (
    <span class="event-row-types">{types.join(' · ')}</span>
  )}
</a>

<style>
  .event-row {
    display: grid;
    grid-template-columns: 6.5rem auto 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    text-decoration: none;
    color: var(--ctp-text);
    border-bottom: 1px solid var(--ctp-surface0);
    transition: background 0.1s;
  }
  .event-row:hover {
    background: var(--ctp-mantle);
  }
  .event-row-date {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ctp-subtext0);
  }
  .event-row-name {
    font-size: 0.9375rem;
  }
  .event-row-types {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ctp-overlay0);
    letter-spacing: 0.04em;
  }
  @media (max-width: 640px) {
    .event-row {
      grid-template-columns: 5.5rem auto 1fr;
    }
    .event-row-types { display: none; }
  }
</style>
