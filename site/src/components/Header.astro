---
import ThemeToggle from './ThemeToggle.astro';
---
<header class="masthead">
  <div class="masthead-inner">
    <a class="masthead-brand" href="/">
      <svg class="masthead-glyph" viewBox="0 0 24 24" aria-hidden="true">
        <!-- finial + staff -->
        <circle class="mg-pole" cx="5.15" cy="2.7" r="1.5"/>
        <rect class="mg-pole" x="4.4" y="2.6" width="1.5" height="18.9" rx="0.75"/>
        <!-- windswept black flag -->
        <path class="mg-flag" d="M5.9 4 C 10 2.7, 14 5.3, 20 3.9 C 18.4 6.1, 18.4 7.4, 20 9.6 C 14 11, 10 8.4, 5.9 9.7 Z"/>
      </svg>
      <div>
        <div class="masthead-name">Black Flag Intelligence</div>
        <div class="masthead-product">AUSPEX</div>
      </div>
    </a>
    <nav class="masthead-nav">
      <a href="/brief">Brief</a>
      <a href="/predict">Predict</a>
      <a href="/calendar">Calendar</a>
      <a href="/explore">Explore</a>
      <a href="/heatmap">Heatmap</a>
      <a href="/states">States</a>
      <a href="/doctrines">Doctrines</a>
      <a href="/actors">Actors</a>
      <a href="/targets">Targets</a>
      <a href="/events">Events</a>
      <a class="nav-search" href="/search" aria-label="Search">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <circle cx="10.5" cy="10.5" r="6.5"/>
          <line x1="20" y1="20" x2="15.2" y2="15.2"/>
        </svg>
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
