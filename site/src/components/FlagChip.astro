---
interface Props {
  state: string | undefined;
  small?: boolean;
}
const { state, small } = Astro.props;
const display = (state ?? '').toUpperCase();
---
{display ? <span class={small ? 'flag-chip flag-chip-sm' : 'flag-chip'}>{display}</span> : null}

<style>
  .flag-chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    padding: 0.125rem 0.4rem;
    border-radius: var(--radius-sm);
    background: var(--ctp-surface0);
    color: var(--ctp-subtext1);
    font-weight: 500;
  }
  .flag-chip-sm {
    font-size: 0.625rem;
    padding: 0.0625rem 0.3rem;
  }
</style>
