    border-left-color: var(--ctp-peach);
    background: color-mix(in srgb, var(--ctp-peach) 9%, var(--ctp-mantle));
  }
  .ood-banner .ood-title {
    margin: 0 0 0.25rem;
    font-weight: 600;
