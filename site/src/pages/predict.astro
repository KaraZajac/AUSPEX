---
import Base from '../layouts/Base.astro';
import { atlas } from '../utils/atlas';

const a = atlas();
const stateOptions = [...a.nationStates.values()].sort((x, y) => x.short_name?.localeCompare(y.short_name ?? '') ?? 0);
const sectorOptions = [...a.sectors.values()].filter((s) => !s.parent_id).sort((x, y) => x.name.localeCompare(y.name));
const incidentTypeOptions = [
  'intrusion', 'data-theft', 'destructive', 'wiper', 'ransomware', 'financial-theft',
  'pre-positioning', 'disruption', 'influence-operation', 'supply-chain', 'documentary',
];
const vectorOptions = [
  'phishing', 'spear-phishing', 'n-day', '0-day', 'supply-chain',
  'valid-creds', 'insider', 'physical', 'unknown',
];
const countryOptions = ['us', 'uk', 'fr', 'de', 'il', 'sa', 'ae', 'qa', 'ua', 'tw', 'kr', 'jp', 'au', 'ca', 'in', 'pk', 'ir', 'ru', 'cn', 'kp', 'tr', 'vn', 'by'];
---
<Base title="Predict" wide>
  <p class="kicker">Live engine</p>
  <h1>Predict</h1>
  <p class="lede">
    Describe a cyber event by its observable features. AUSPEX runs
    all four engines against the description and returns ranked
    candidates — doctrine, pillar, actor, and the joint
    (actor × doctrine) pair.
  </p>
  <p class="meta">
    Calibrated against the <a href="/research/temporal-eval">temporal-holdout
    backtest</a> (train ≤ 2023-12-31, score 2024–2026 cold): doctrine
    top-3 hit ≈ 84%, actor top-5 hit ≈ 69%, joint pair top-1 ≈ 58%.
  </p>

  <div id="loading" class="loading">Loading atlas…</div>

  <form id="predict-form" class="predict-form" style="display: none;">
    <div class="grid">
      <div class="field">
        <label>Target sector(s) <span class="hint">multi-select</span></label>
        <div id="sector-options" class="checks">
          {sectorOptions.map((s) => (
            <label class="check"><input type="checkbox" name="sector" value={s.id} /> <span>{s.name}</span></label>
          ))}
        </div>
      </div>

      <div class="field">
        <label>Target country</label>
        <select name="country">
          <option value="">— any —</option>
          {countryOptions.map((c) => <option value={c}>{c.toUpperCase()}</option>)}
        </select>

        <label style="margin-top: 0.875rem;">Year</label>
        <input type="number" name="year" value="2026" min="2000" max="2030" />

        <label style="margin-top: 0.875rem;">Initial vector</label>
        <select name="vector">
          <option value="">— unknown —</option>
          {vectorOptions.map((v) => <option value={v}>{v}</option>)}
        </select>
      </div>

      <div class="field">
        <label>Incident type(s) <span class="hint">multi-select</span></label>
        <div class="checks">
          {incidentTypeOptions.map((t) => (
            <label class="check"><input type="checkbox" name="incidentType" value={t} /> <span>{t}</span></label>
          ))}
        </div>
      </div>

      <div class="field">
        <label>Free-text description <span class="hint">malware / tradecraft keywords extracted automatically</span></label>
        <textarea name="description" rows="6" placeholder="Paste the event description, advisory text, or news summary. The engine scans for malware family names (PlugX, ShadowPad, Mimikatz, Cobalt Strike, etc.) and tradecraft phrases (living off the land, DLL side-loading, valid credentials, web shell)."></textarea>

        <label style="margin-top: 0.625rem;">Explicit malware families <span class="hint">comma-separated, optional — lineage-aware matching</span></label>
        <input type="text" name="malware" placeholder="ShadowPad, PlugX, Cobalt Strike" />

        <label style="margin-top: 0.625rem;">Named operators <span class="hint">indictment-named individuals; surname-given slug, comma-separated</span></label>
        <input type="text" name="operators" placeholder="lashgarian-hamid-reza, vasinskyi-yaroslav, park-jin-hyok" />
      </div>
    </div>

    <div class="actions">
      <button type="submit" class="primary">Predict</button>
      <button type="reset" class="secondary">Reset</button>
      <span id="status" class="status"></span>
    </div>
  </form>

  <div id="results" class="results"></div>
</Base>

<script>
  // ── ISOMORPHIC ENGINE ────────────────────────────────────────────────
  // This is a BUNDLED module script (not is:inline) — Astro/Vite bundles
  // and tree-shakes it. It imports the EXACT same prediction engine the
  // server evals use, so there is a single source of truth and no
  // server-vs-browser drift. The only browser-specific code is the DOM /
  // form / rendering layer below.
  import { atlasFromPayload, type Atlas, type AuspexEvent, type DoctrinePillar } from '../utils/atlas-core';
  import {
    extractFeatures,
    buildProfiles,
    buildVocab,
    buildIDF,
    rankActors,
    type EventFeatures,
    type ActorProfile,
    type Vocab,
    type IDFMap,
  } from '../utils/attribution';
  import {
    buildDoctrineProfiles,
    buildDoctrineIDF,
    rankDoctrines,
    type DoctrineProfile,
  } from '../utils/doctrine-prediction';
  import {
    buildPillarProfiles,
    buildPillarIDF,
    rankPillars,
    type PillarProfile,
  } from '../utils/pillar-prediction';
  import { rankPairs } from '../utils/joint-prediction';
  import { computeOOD } from '../utils/ood';
  import { calibratedProbs, CALIBRATION } from '../utils/calibration-constants';

  const SERVICE_PRIOR_LAMBDA = 0.2; // matches the deployed eval (AUDIT-2026-05-29 B1)
  const CURRENT_YEAR = new Date().getFullYear();

  // Per-request engine state — the reconstructed Atlas plus the profiles /
  // vocab / IDF built for the current reference year. Rebuilt on year change.
  let ATLAS: Atlas;                          // Atlas instance (from atlasFromPayload)
  let ALL_EVENTS: AuspexEvent[];             // [...ATLAS.events.values()]
  let PILLAR_INDEX: Map<string, { pillar: DoctrinePillar; doctrineId: string }>; // for rendering
  let ACTOR_PROFILES: Map<string, ActorProfile>;
  let DOCTRINE_PROFILES: Map<string, DoctrineProfile>;
  let PILLAR_PROFILES: Map<string, PillarProfile>;
  let VOCAB: Vocab;
  let ACTOR_IDF: IDFMap;
  let DOCTRINE_IDF: IDFMap;
  let PILLAR_IDF: IDFMap;
  let LAST_BUILD_REF_YEAR: number | null = null;

  // ── load atlas ─────────────────────────────────────────────────────
  async function loadAtlas() {
    const r = await fetch('/api/atlas.json');
    if (!r.ok) throw new Error('Failed to load atlas');
    const payload = await r.json();
    // Reconstruct the SAME Atlas the server builds (entity Maps, derived
    // indices, knownMalware, malware-lineage, inferredCampaignByEvent).
    ATLAS = atlasFromPayload(payload);
    ALL_EVENTS = [...ATLAS.events.values()];

    PILLAR_INDEX = new Map();
    for (const d of ATLAS.doctrines.values()) {
      for (const p of d.pillars ?? []) {
        PILLAR_INDEX.set(p.id, { pillar: p, doctrineId: d.id });
      }
    }

    // Initial profile build, weighted toward the current year. The
    // renderResults path rebuilds per-query if the user enters a different
    // reference year.
    rebuildProfilesForYear(CURRENT_YEAR);
  }

  // Build all three profile families through the SHARED engine, temporally
  // weighted toward refYear (exp(-|Δyears|/tau), tau=3, identical to the
  // server temporal path), with the λ=0.2 service prior on actors only.
  function rebuildProfilesForYear(refYear: number) {
    if (LAST_BUILD_REF_YEAR === refYear) return;
    const referenceDate = Number.isFinite(refYear) ? String(refYear) : null;
    const buildOpts = referenceDate ? { referenceDate } : {};
    ACTOR_PROFILES = buildProfiles(ALL_EVENTS, ATLAS, { ...buildOpts, servicePriorLambda: SERVICE_PRIOR_LAMBDA });
    DOCTRINE_PROFILES = buildDoctrineProfiles(ALL_EVENTS, ATLAS, buildOpts);
    PILLAR_PROFILES = buildPillarProfiles(ALL_EVENTS, ATLAS, buildOpts);
    VOCAB = buildVocab(ALL_EVENTS, ATLAS);
    ACTOR_IDF = buildIDF(ACTOR_PROFILES);
    DOCTRINE_IDF = buildDoctrineIDF(DOCTRINE_PROFILES);
    PILLAR_IDF = buildPillarIDF(PILLAR_PROFILES);
    LAST_BUILD_REF_YEAR = refYear;
  }

  // ── form handling ──────────────────────────────────────────────────
  // Build a synthetic AuspexEvent from the form so we can run the REAL
  // extractFeatures (no parallel extractor). Form sectors are already
  // top-level ids; wrap them as `sectors/<id>` targets (extractFeatures
  // rolls each back up to itself). Description maps to `summary` so the
  // shared TTP / malware keyword scanners see it. The form has no date,
  // attributions, or named org/infra targets, so markers / inferred-
  // campaign / named-targets come out empty — exactly what the server
  // would produce for such a feature vector.
  /** Read a named form field's string value (input / select / textarea). */
  function fieldValue(form: HTMLFormElement, name: string): string {
    const el = form.querySelector(`[name="${name}"]`) as
      HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null;
    return el?.value ?? '';
  }

  function formToEvent(form: HTMLFormElement): AuspexEvent {
    const targets: Array<{ target_id: string; country?: string }> = [];
    form.querySelectorAll('input[name="sector"]:checked').forEach((el) => {
      targets.push({ target_id: 'sectors/' + (el as HTMLInputElement).value });
    });
    const country = fieldValue(form, 'country').trim().toLowerCase();
    if (country) {
      // Attach the country to a target row so extractFeatures picks it up.
      if (targets.length > 0) targets[0].country = country;
      else targets.push({ target_id: 'country/' + country, country });
    }
    const yearStr = fieldValue(form, 'year');
    const vector = fieldValue(form, 'vector') || undefined;
    const description = fieldValue(form, 'description');
    const malwareInput = fieldValue(form, 'malware');
    const incidentTypes: string[] = [];
    form.querySelectorAll('input[name="incidentType"]:checked').forEach((el) => incidentTypes.push((el as HTMLInputElement).value));
    const operators = fieldValue(form, 'operators')
      .split(',').map((s) => s.trim().toLowerCase()).filter(Boolean);

    // Fold the explicit-malware box into the summary text so the SHARED
    // malware/TTP scanners (which read summary + outcome_summary) see it —
    // keeping extractFeatures and computeOOD consistent on one event object.
    const summary = malwareInput.trim() ? `${description}\n${malwareInput}` : description;

    return {
      id: '__query__',
      name: '',
      start_date: /^\d{4}$/.test(yearStr) ? `${yearStr}-01-01` : undefined,
      initial_vector: vector,
      incident_type: incidentTypes,
      summary,
      operators_named: operators,
      targets,
      attributions: [],
      doctrine_links: [],
    };
  }

  function readFormQuery(): { event: AuspexEvent; features: EventFeatures } {
    const form = document.getElementById('predict-form') as HTMLFormElement;
    const event = formToEvent(form);
    // Run the SAME extractor the engine/eval use.
    const features = extractFeatures(event, ATLAS);
    // The explicit-malware box may name families outside the corpus's
    // known-malware vocabulary (so the summary regex above misses them);
    // append those raw tokens to the ranking feature set so the actor
    // engine can still match an actor's own malware list, mirroring the
    // prior form behavior. (OOD uses the corpus-grounded extraction only.)
    const malwareInput = fieldValue(form, 'malware');
    for (const raw of malwareInput.split(',').map((s) => s.trim().toLowerCase()).filter(Boolean)) {
      features.malware.add(raw);
    }
    return { event, features };
  }

  // ── match-reason reconstruction (for the actor-card badges) ──────────
  // The shared scoreActor returns only a score; recompute which features
  // fired so we can surface the explanatory badges. Mirrors the matching
  // logic in attribution.ts (operators / campaign / named targets / malware
  // exact + lineage-group partial).
  interface MatchReasons {
    operators: string[];
    campaign: string | null;
    malware: string[];
    targets: string[];
    malwareLineage: Array<{ family: string; group: string }>;
  }
  function matchReasonsFor(features: EventFeatures, profile: ActorProfile | undefined): MatchReasons {
    const reasons: MatchReasons = { operators: [], campaign: null, malware: [], targets: [], malwareLineage: [] };
    if (!profile) return reasons;
    if (features.operators.size > 0 && profile.operators.size > 0) {
      for (const op of features.operators) if (profile.operators.has(op)) reasons.operators.push(op);
    }
    if (features.campaign && profile.campaigns.size > 0) {
      if ((profile.campaigns.get(features.campaign) ?? 0) > 0) reasons.campaign = features.campaign;
    }
    if (features.targets.size > 0 && profile.targets.size > 0) {
      for (const t of features.targets) if (profile.targets.has(t)) reasons.targets.push(t);
    }
    if (features.malware.size > 0 && profile.malware.size > 0) {
      const lineageMap = ATLAS.malwareLineageGroup;
      const profileGroups = new Set<string>();
      for (const m of profile.malware) {
        const lg = lineageMap.get(String(m).toLowerCase());
        if (lg) profileGroups.add(lg);
      }
      for (const m of features.malware) {
        if (profile.malware.has(m)) { reasons.malware.push(m); continue; }
        const lg = lineageMap.get(String(m).toLowerCase());
        if (lg && profileGroups.has(lg)) reasons.malwareLineage.push({ family: m, group: lg });
      }
    }
    return reasons;
  }

  // ── render helpers ───────────────────────────────────────────────────
  function actorName(id: string): string {
    const a = ATLAS.actors.get(id);
    return a?.canonical_name ?? id;
  }
  function doctrineName(id: string): string {
    const d = ATLAS.doctrines.get(id);
    return d?.short_name ?? d?.name ?? id;
  }
  function pillarName(id: string): string {
    const ref = PILLAR_INDEX.get(id);
    if (!ref) return id;
    return doctrineName(ref.doctrineId) + ' › ' + ref.pillar.name;
  }

  interface Scored { id: string; score: number; reasons?: MatchReasons }
  interface ScoredPair { actorId: string; doctrineId: string; co: number; jointScore: number }

  // Temperature-scaled softmax over a wide (top-20) pool so calibrated
  // probabilities reflect competition with all reasonable candidates, not
  // just the displayed top-k. Uses the shared calibratedProbs (pure).
  function softmaxTop<T>(items: T[], getScore: (x: T) => number, k: number, temperature: number): Array<T & { prob: number }> {
    const widePool = items.slice(0, Math.max(20, k));
    const probs = calibratedProbs(widePool.map(getScore), temperature ?? 1.0);
    return widePool.slice(0, k).map((x, i) => ({ ...x, prob: probs[i] ?? 0 }));
  }

  function renderResults(query: { event: AuspexEvent; features: EventFeatures }): void {
    const { event: queryEvent, features } = query;
    const root = document.getElementById('results');
    if (!root) return;
    const refYear = features.year ? parseInt(features.year, 10) : CURRENT_YEAR;
    rebuildProfilesForYear(Number.isFinite(refYear) ? refYear : CURRENT_YEAR);

    // Run the SHARED ranking engines. Normalize outputs to {id, score} so
    // the rendering layer stays engine-agnostic.
    const actors: Scored[] = rankActors(features, ACTOR_PROFILES, VOCAB, { idf: ACTOR_IDF, malwareLineageGroup: ATLAS.malwareLineageGroup })
      .map((x) => ({ id: x.actorId, score: x.logScore }));
    const doctrines: Scored[] = rankDoctrines(features, DOCTRINE_PROFILES, VOCAB, { idf: DOCTRINE_IDF })
      .map((x) => ({ id: x.doctrineId, score: x.logScore }));
    const pillars: Scored[] = rankPillars(features, PILLAR_PROFILES, VOCAB, { idf: PILLAR_IDF })
      .map((x) => ({ id: x.pillarId, score: x.logScore }));
    // Joint engine: shared rankPairs rebuilds its own (no-prior) profiles +
    // co-occurrence internally — the canonical joint behavior the eval uses.
    const referenceDate = Number.isFinite(refYear) ? String(refYear) : null;
    const pairs: ScoredPair[] = rankPairs(features, ALL_EVENTS, ATLAS, referenceDate ? { referenceDate } : {})
      .map((x) => ({ actorId: x.actorId, doctrineId: x.doctrineId, co: x.coOccurrence, jointScore: x.jointScore }));

    // Calibrated probabilities — temperature-scaled softmax over the top-20
    // pool. Calibration constants fit against LOO log-loss; see
    // src/utils/calibration-constants.ts.
    const actorTop = softmaxTop(actors, (x) => x.score, 5, CALIBRATION.attribution.temperature);
    const doctrineTop = softmaxTop(doctrines, (x) => x.score, 3, CALIBRATION.doctrine.temperature);
    const pillarTop = softmaxTop(pillars, (x) => x.score, 3, CALIBRATION.pillar.temperature);
    const pairTop = softmaxTop(pairs, (x) => x.jointScore, 3, CALIBRATION.attribution.temperature);

    // Reconstruct the explanatory badges for the displayed actors.
    for (const a of actorTop) a.reasons = matchReasonsFor(features, ACTOR_PROFILES.get(a.id));

    // OOD via the shared engine — score the synthetic query event against
    // the full corpus. computeOOD re-extracts the query internally; the same
    // event object that produced `features` reproduces the OOD feature set.
    const ood = computeOOD(queryEvent, ALL_EVENTS, ATLAS);

    function fmtPct(p: number): string { return (p * 100).toFixed(1) + '%'; }

    const oodNearestLink = ood.nearestEventId
      ? `<a href="/event/${ood.nearestEventId}">${escapeHtml(ood.nearestEventId)}</a>`
      : '<em>none</em>';

    const oodBanner = (ood.tier === 'out-of-distribution' || ood.tier === 'borderline') ? `
      <section class="ood-banner ood-${ood.tier}">
        <p class="ood-title">
          ${ood.tier === 'out-of-distribution' ? '⚠ Out-of-distribution' : 'Borderline match'}
          <span class="ood-num">distance = ${ood.distance.toFixed(2)}</span>
        </p>
        <p class="ood-body">
          ${ood.tier === 'out-of-distribution'
            ? "This event description doesn't closely match anything in the corpus. Engine predictions below are based on the best available training signal but should be treated with caution. This is the kind of case where the engine may be confidently wrong — review the nearest neighbor below and your own technical assessment before relying on the rankings."
            : 'This event has only loose similarity to events in the corpus. Top predictions are still informative but less certain than for well-matched events.'}
        </p>
        <p class="ood-nearest">Nearest training event: ${oodNearestLink} (${fmtPct(ood.nearestSimilarity)} feature overlap, ${ood.closeNeighborCount} events with ≥30% overlap).</p>
      </section>
    ` : `
      <section class="ood-banner ood-in-distribution">
        <p class="ood-title">In-distribution
          <span class="ood-num">distance = ${ood.distance.toFixed(2)}</span>
        </p>
        <p class="ood-body">This event description matches training corpus patterns. Engine predictions below carry their typical reliability (see calibration footer).</p>
        <p class="ood-nearest">Nearest training event: ${oodNearestLink} (${fmtPct(ood.nearestSimilarity)} feature overlap).</p>
      </section>
    `;

    root.innerHTML = `
      <h2>Results</h2>
      ${oodBanner}
      <div class="results-grid">
        <section class="rcard">
          <h3>Doctrine <span class="cal">temporal top-3: 84%</span></h3>
          ${doctrineTop.map((d, i) => `
            <div class="row">
              <span class="rank">${i + 1}</span>
              <a class="lbl" href="/doctrine/${d.id}">${escapeHtml(doctrineName(d.id))}</a>
              <span class="prob">${fmtPct(d.prob)}</span>
            </div>
          `).join('')}
        </section>

        <section class="rcard">
          <h3>Pillar <span class="cal">temporal top-3: 71%</span></h3>
          ${pillarTop.map((p, i) => `
            <div class="row">
              <span class="rank">${i + 1}</span>
              <a class="lbl" href="/doctrine/${PILLAR_INDEX.get(p.id)?.doctrineId ?? ''}">${escapeHtml(pillarName(p.id))}</a>
              <span class="prob">${fmtPct(p.prob)}</span>
            </div>
          `).join('')}
        </section>

        <section class="rcard rcard-wide">
          <h3>Actor — candidate shortlist <span class="cal">temporal top-5: 69%</span></h3>
          ${actorTop.map((a, i) => {
            const r: MatchReasons = a.reasons ?? { operators: [], campaign: null, malware: [], targets: [], malwareLineage: [] };
            const badges: string[] = [];
            if (r.operators.length > 0) badges.push(`<span class="badge badge-op" title="Matched named operator(s): ${r.operators.join(', ')}">👤 operator: ${escapeHtml(r.operators[0])}${r.operators.length > 1 ? ` +${r.operators.length-1}` : ''}</span>`);
            if (r.campaign) badges.push(`<span class="badge badge-cam" title="Actor previously seen in this campaign cluster">🧵 ${escapeHtml(r.campaign)}</span>`);
            if (r.targets.length > 0) badges.push(`<span class="badge badge-tgt" title="Matched named target(s): ${r.targets.join(', ')}">🎯 ${escapeHtml(r.targets[0])}${r.targets.length > 1 ? ` +${r.targets.length-1}` : ''}</span>`);
            if (r.malware.length > 0) badges.push(`<span class="badge badge-mw" title="Matched malware family/families: ${r.malware.join(', ')}">⚙ ${escapeHtml(r.malware[0])}${r.malware.length > 1 ? ` +${r.malware.length-1}` : ''}</span>`);
            if (r.malwareLineage.length > 0) {
              const lg = r.malwareLineage[0];
              badges.push(`<span class="badge badge-lin" title="Lineage-group partial match (different family, same code lineage): ${r.malwareLineage.map((x) => x.family + ' → ' + x.group).join(', ')}">🧬 lineage: ${escapeHtml(lg.group)}</span>`);
            }
            const badgeHtml = badges.length > 0 ? `<div class="badges">${badges.join('')}</div>` : '';
            return `
              <div class="row rich">
                <span class="rank">${i + 1}</span>
                <div class="lbl-col">
                  <a class="lbl" href="/actor/${a.id}">${escapeHtml(actorName(a.id))}</a>
                  ${badgeHtml}
                </div>
                <span class="prob">${fmtPct(a.prob)}</span>
              </div>
            `;
          }).join('')}
        </section>

        <section class="rcard rcard-wide">
          <h3>Joint pair — confidence layer <span class="cal">temporal top-1: 58%</span></h3>
          ${pairTop.map((pair, i) => {
            const confTag = pair.co >= 5 ? 'HIGH' : pair.co >= 2 ? 'MED' : pair.co === 0 ? 'NOVEL' : 'LOW';
            const confClass = pair.co >= 5 ? 'conf-high' : pair.co >= 2 ? 'conf-med' : pair.co === 0 ? 'conf-novel' : 'conf-low';
            return `
              <div class="pair-row">
                <span class="rank">${i + 1}</span>
                <span class="pair-lbl">
                  <a href="/actor/${pair.actorId}">${escapeHtml(actorName(pair.actorId))}</a>
                  × <a href="/doctrine/${pair.doctrineId}">${escapeHtml(doctrineName(pair.doctrineId))}</a>
                </span>
                <span class="conf ${confClass}">${confTag}</span>
                <span class="co">co-occurrence ${pair.co}</span>
              </div>
            `;
          }).join('')}
          <p class="reading">
            <strong>HIGH</strong> co-occurrence ≥ 5 — engine has seen this
            pair many times and is confident.
            <strong>MED</strong> ≥ 2 — recurrent pattern.
            <strong>LOW</strong> 1 — sparse but observed.
            <strong>NOVEL</strong> 0 — engine has never seen this pair;
            either a real novel attribution or a sign of cross-engine
            disagreement.
          </p>
        </section>
      </div>

      <section>
        <h3>Extracted features</h3>
        <ul class="fdump">
          <li><strong>sectors</strong>: ${[...features.sectors].join(', ') || '<em>none</em>'}</li>
          <li><strong>countries</strong>: ${[...features.countries].join(', ') || '<em>none</em>'}</li>
          <li><strong>vector</strong>: ${features.vector || '<em>none</em>'}</li>
          <li><strong>year</strong>: ${features.year || '<em>none</em>'}</li>
          <li><strong>incident types</strong>: ${[...features.incidentTypes].join(', ') || '<em>none</em>'}</li>
          <li><strong>ttps (inferred)</strong>: ${[...features.ttps].join(', ') || '<em>none</em>'}</li>
          <li><strong>malware (extracted)</strong>: ${[...features.malware].join(', ') || '<em>none</em>'}</li>
        </ul>
      </section>
    `;
  }

  function escapeHtml(s: unknown): string {
    const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' };
    return String(s).replace(/[&<>"']/g, (c) => map[c] ?? c);
  }

  // ── bootstrap ──────────────────────────────────────────────────────
  async function boot() {
    const loading = document.getElementById('loading');
    const form = document.getElementById('predict-form');
    if (!loading || !form) return;
    try {
      loading.textContent = 'Loading atlas (1.7 MB)…';
      await loadAtlas();
      loading.textContent = 'Building profiles…';
      // (already done at end of loadAtlas)
      loading.style.display = 'none';
      (form as HTMLElement).style.display = '';
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const query = readFormQuery();
        renderResults(query);
        document.getElementById('results')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      form.addEventListener('reset', () => {
        setTimeout(() => { const r = document.getElementById('results'); if (r) r.innerHTML = ''; }, 0);
      });
    } catch (err) {
      loading.textContent = 'Failed to load atlas: ' + (err instanceof Error ? err.message : String(err));
    }
  }
  boot();
</script>

