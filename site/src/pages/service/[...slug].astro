---
import Base from '../../layouts/Base.astro';
import FlagChip from '../../components/FlagChip.astro';
import EventRow from '../../components/EventRow.astro';
import { atlas } from '../../utils/atlas';

export function getStaticPaths() {
  const a = atlas();
  return [...a.services.values()].map((s) => ({
    params: { slug: s.id },
    props: { serviceId: s.id },
  }));
}

const { serviceId } = Astro.props as { serviceId: string };
const a = atlas();
const svc = a.services.get(serviceId)!;
const parent = svc.parent_service_id ? a.services.get(svc.parent_service_id) : undefined;
const subServices = a.childServices(svc.id);
const directActors = a.actorsForService(svc.id);
const recursiveActors = a.actorsForServiceRecursive(svc.id);
// Events attributed at the service level (via service_id in attributions)
const events = a.allEventsSorted().filter((ev) =>
  (ev.attributions ?? []).some((attr) => attr.service_id === serviceId),
);
---
<Base title={svc.name} wide>
  <p class="kicker">Service</p>
  <div class="svc-header">
    <FlagChip state={svc.nation_state_id} />
    <h1 style="margin:0;">{svc.name}</h1>
    {svc.short_name && <span class="short">{svc.short_name}</span>}
    {svc.active_until && <span class="status-chip">disbanded</span>}
  </div>
  <p class="meta"><code>{svc.id}</code></p>

  {parent && (
    <p class="meta">Parent service: <a href={`/service/${parent.id}`}>{parent.name}</a></p>
  )}

  {svc.aliases && svc.aliases.length > 0 && (
    <p class="meta">Also known as: {svc.aliases.map((a) => <code style="margin-right: 0.5rem;">{a}</code>)}</p>
  )}

  {svc.active_since && (
    <p class="meta">
      Active since <strong>{svc.active_since}</strong>
      {svc.active_until && <> &mdash; until {svc.active_until}</>}
    </p>
  )}

  {svc.mission && <section><h2>Mission</h2><p style="white-space: pre-line;">{svc.mission}</p></section>}

  {svc.summary && (
    <section>
      <h2>Summary</h2>
      <p style="white-space: pre-line;">{svc.summary}</p>
    </section>
  )}

  {subServices.length > 0 && (
    <section>
      <h2>Sub-services</h2>
      <ul>
        {subServices.map((sub) => (
          <li>
            <a href={`/service/${sub.id}`}>{sub.name}</a>
            {sub.short_name && <> ({sub.short_name})</>}
            <span class="state-hint"> &nbsp; <code>{sub.id}</code></span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <h2>Actors ({recursiveActors.length})</h2>
    {recursiveActors.length === 0 ? (
      <p style="color: var(--ctp-subtext0);">No actors currently attributed to this service.</p>
    ) : (
      <div class="chip-row">
        {recursiveActors.map((act) => (
          <a class="actor-chip" href={`/actor/${act.id}`}>{act.canonical_name}</a>
        ))}
      </div>
    )}
    {subServices.length > 0 && directActors.length > 0 && directActors.length !== recursiveActors.length && (
      <p class="meta" style="margin-top: 0.5rem;">
        {directActors.length} directly under this service; the rest under sub-services.
      </p>
    )}
  </section>

  {events.length > 0 && (
    <section>
      <h2>Service-level attributions ({events.length})</h2>
      <p style="color: var(--ctp-subtext0); font-size: 0.875rem;">
        Events where the attributing source named this service but did not
        name a specific actor cluster.
      </p>
      <div class="event-list">
        {events.map((ev) => <EventRow event={ev} />)}
      </div>
    </section>
  )}
</Base>

<style>
  .svc-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 1rem 0 0.5rem;
  }
  .short { font-family: var(--font-mono); color: var(--ctp-subtext0); }
  .meta { color: var(--ctp-subtext0); margin: 0 0 0.5rem; font-size: 0.9375rem; }
  .state-hint { color: var(--ctp-overlay0); font-family: var(--font-mono); font-size: 0.8125rem; }
  .chip-row { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .actor-chip {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--ctp-surface0);
    color: var(--ctp-text);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .actor-chip:hover { background: var(--ctp-blue); color: var(--ctp-base); }
  .status-chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: var(--ctp-overlay0);
    color: var(--ctp-base);
    padding: 0.125rem 0.4rem;
    border-radius: var(--radius-sm);
  }
  .event-list {
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .event-list :global(.event-row:last-child) { border-bottom: none; }
</style>
