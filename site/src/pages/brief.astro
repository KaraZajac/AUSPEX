---
import Base from '../layouts/Base.astro';

// Manually curated brief manifest. As we add briefs, add entries here in
// reverse-chronological order. (We can switch to content collections once
// the cadence justifies it.)
const briefs = [
  {
    slug: '2026-05-26',
    title: 'Typhoon Bifurcation: two PRC pillars, one strategic window',
    date: '2026-05-26',
    lede:
      "Volt Typhoon and Salt Typhoon are the same service running two different doctrinal mandates against the same victim country. The bifurcation matters — and it's been hiding in plain sight.",
  },
];
---
<Base title="Brief" wide>
  <p class="kicker">Brief</p>
  <h1>The Sunday Brief</h1>
  <p class="lede">
    A weekly synthesis of what shifted in cyber-doctrine space.
    Source-anchored, opinion-clear, written for analysts and journalists
    who need the strategic frame before the next deadline.
  </p>

  <div class="brief-list">
    {briefs.map((b) => (
      <a class="brief-row" href={`/brief/${b.slug}`}>
        <span class="brief-date">{b.date}</span>
        <div class="brief-body">
          <h3 class="brief-title">{b.title}</h3>
          <p class="brief-lede">{b.lede}</p>
        </div>
      </a>
    ))}
  </div>

  <p style="margin-top: 2rem; color: var(--ctp-subtext0); font-size: 0.875rem;">
    Subscribe via <a href="/rss.xml">RSS</a>.
  </p>
</Base>

<style>
  .brief-list {
    margin-top: 1.5rem;
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .brief-row {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--ctp-surface0);
    text-decoration: none;
    color: var(--ctp-text);
  }
  .brief-row:last-child { border-bottom: none; }
  .brief-row:hover { background: var(--ctp-mantle); }
  .brief-date {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ctp-subtext0);
    padding-top: 0.125rem;
  }
  .brief-title {
    margin: 0 0 0.375rem;
    font-size: 1.125rem;
    font-family: var(--font-mono);
  }
  .brief-lede {
    margin: 0;
    color: var(--ctp-subtext1);
    font-size: 0.9375rem;
  }
</style>
