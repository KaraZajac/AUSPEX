---
import Base from '../../layouts/Base.astro';
import FlagChip from '../../components/FlagChip.astro';
import EventRow from '../../components/EventRow.astro';
import AttributionDonut from '../../components/AttributionDonut.astro';
import PillarBreakdown from '../../components/PillarBreakdown.astro';
import AttributionMap from '../../components/AttributionMap.astro';
import EventTimeline from '../../components/EventTimeline.astro';
import { atlas } from '../../utils/atlas';

export function getStaticPaths() {
  const a = atlas();
  return [...a.doctrines.values()].map((d) => ({
    params: { slug: d.id },
    props: { doctrineId: d.id },
  }));
}

const { doctrineId } = Astro.props as { doctrineId: string };
const a = atlas();
const doctrine = a.doctrines.get(doctrineId);
if (!doctrine) {
  throw new Error(`doctrine not found: ${doctrineId}`);
}
const state = doctrine.nation_state_id;
const events = a.eventsForDoctrine(doctrine.id);
const actors = a.actorsForDoctrine(doctrine.id);
const markers = a.markersForDoctrine(doctrine.id);
const supersededBy = doctrine.superseded_by_id ? a.doctrines.get(doctrine.superseded_by_id) : undefined;
const attribution = a.actorAttributionForDoctrine(doctrine.id);
const TOP_N = 9;
let attributionSlices = attribution;
if (attribution.length > TOP_N + 1) {
  const top = attribution.slice(0, TOP_N);
  const rest = attribution.slice(TOP_N).filter((s) => s.id !== null);
  const unattr = attribution.find((s) => s.id === null);
  const tailCount = rest.reduce((sum, s) => sum + s.count, 0);
  const total = attribution.reduce((sum, s) => sum + s.count, 0);
  const merged = [...top];
  if (tailCount > 0) {
    merged.push({
      id: '__other__',
      name: `${rest.length} other actor${rest.length === 1 ? '' : 's'}`,
      count: tailCount,
      percent: (tailCount / total) * 100,
    });
  }
  if (unattr && !top.find((s) => s.id === null)) merged.push(unattr);
  attributionSlices = merged;
}
const attributionTotal = attribution.reduce((sum, s) => sum + s.count, 0);

// Pillar breakdown for the doctrine
const pillarBreakdown = a.pillarBreakdownForDoctrine(doctrine.id);
const pillarTotal = pillarBreakdown.reduce((sum, p) => sum + p.count, 0);

// Doctrines this one inherits from (predecessor chain) or that inherit from it
const inheritsFrom = (doctrine.inherits_from_ids ?? [])
  .map((id) => a.doctrines.get(id))
  .filter((d): d is NonNullable<typeof d> => !!d);
const inheritedBy = [...a.doctrines.values()].filter((d) =>
  (d.inherits_from_ids ?? []).includes(doctrine.id),
);
---
<Base title={doctrine.name} wide>
  <p class="kicker">Doctrine</p>
  <div class="doctrine-header">
    <FlagChip state={state} />
    <h1 style="margin:0;">{doctrine.name}</h1>
    {doctrine.status && doctrine.status !== 'active' && (
      <span class="status-chip status-{doctrine.status}">{doctrine.status}</span>
    )}
  </div>
  {doctrine.issued_by && (
    <p class="meta">
      Issued by <strong>{doctrine.issued_by}</strong>
      {doctrine.issued_on && <> on {doctrine.issued_on}</>}
    </p>
  )}
  {supersededBy && (
    <p class="meta">Superseded by <a href={`/doctrine/${supersededBy.id}`}>{supersededBy.name}</a></p>
  )}
  {doctrine.official_text_url && (
    <p class="meta"><a href={doctrine.official_text_url} target="_blank" rel="noopener noreferrer">Official text →</a></p>
  )}

  {doctrine.summary && (
    <section>
      <h2>Summary</h2>
      <p style="white-space: pre-line;">{doctrine.summary}</p>
    </section>
  )}

  {doctrine.cyber_relevance && (
    <section>
      <h2>Cyber relevance</h2>
      <p style="white-space: pre-line;">{doctrine.cyber_relevance}</p>
    </section>
  )}

  {events.length > 0 && (
    <section>
      <p class="kicker">Target geography</p>
      <h2 style="margin-top: 0;">Where this doctrine lands</h2>
      <p style="color: var(--ctp-subtext0); font-size: 0.875rem; margin-bottom: 0.75rem;">
        Countries hit by events serving this doctrine. The map is the
        operational footprint — visual evidence of what the doctrine
        actually targets, distinct from its written framing.
      </p>
      <AttributionMap events={events} selfIso2={state || null} />
    </section>
  )}

  {events.length > 0 && (
    <section>
      <p class="kicker">Doctrine activity</p>
      <h2 style="margin-top: 0;">Year-by-year invocation</h2>
      <p style="color: var(--ctp-subtext0); font-size: 0.875rem; margin-bottom: 0.75rem;">
        Events tagged to this doctrine by year. Red markers show
        doctrine-relevant geopolitical timeline events (issuance,
        supersession, key regime shifts).
      </p>
      <EventTimeline events={events} markers={markers} />
    </section>
  )}

  {(inheritsFrom.length > 0 || inheritedBy.length > 0 || supersededBy) && (
    <section>
      <p class="kicker">Doctrine genealogy</p>
      <h2 style="margin-top: 0;">Relationships</h2>
      <ul class="genealogy">
        {inheritsFrom.map((d) => (
          <li><strong>↑ Inherits from:</strong> <a href={`/doctrine/${d.id}`}>{d.short_name ?? d.name}</a></li>
        ))}
        {inheritedBy.map((d) => (
          <li><strong>↓ Inherited by:</strong> <a href={`/doctrine/${d.id}`}>{d.short_name ?? d.name}</a></li>
        ))}
        {supersededBy && (
          <li><strong>→ Superseded by:</strong> <a href={`/doctrine/${supersededBy.id}`}>{supersededBy.short_name ?? supersededBy.name}</a></li>
        )}
      </ul>
    </section>
  )}

  {attributionTotal > 0 && (
    <section>
      <h2>Who serves this doctrine</h2>
      <p style="color: var(--ctp-subtext0); font-size: 0.875rem; margin-bottom: 1rem;">
        Attributed actors across events tagged to this doctrine (or any of
        its pillars or programs). Multiple actors per event are each counted
        once; events without a named actor go into the doctrine-only bucket.
      </p>
      <AttributionDonut slices={attributionSlices} total={attributionTotal} />
    </section>
  )}

  {pillarTotal > 0 && pillarBreakdown.length > 1 && (
    <section>
      <h2>Pillar breakdown</h2>
      <p style="color: var(--ctp-subtext0); font-size: 0.875rem; margin-bottom: 0.75rem;">
        Distribution of {pillarTotal} doctrine-link{pillarTotal === 1 ? '' : 's'} across this doctrine's pillars.
        Events that link to programs roll up into their parent pillar.
      </p>
      <PillarBreakdown slices={pillarBreakdown} total={pillarTotal} />
    </section>
  )}

  {doctrine.pillars && doctrine.pillars.length > 0 && (
    <section>
      <h2>Pillars</h2>
      <div class="pillars">
        {doctrine.pillars.map((p) => {
          const pillarEvents = a.eventsForPillar(p.id);
          return (
            <article class="pillar">
              <h3 style="margin:0 0 0.25rem;">{p.name}</h3>
              <p class="pillar-id">{p.id}</p>
              {p.summary && <p style="white-space: pre-line;">{p.summary}</p>}
              {p.target_sectors && p.target_sectors.length > 0 && (
                <div class="chip-row">
                  {p.target_sectors.map((s) => <span class="sector-chip">{s}</span>)}
                </div>
              )}
              {p.programs && p.programs.length > 0 && (
                <div class="programs">
                  <p class="kicker" style="margin: 1rem 0 0.5rem;">Programs</p>
                  {p.programs.map((pg) => (
                    <article class="program">
                      <strong>{pg.name}</strong>
                      {pg.summary && <p style="margin: 0.25rem 0 0; white-space: pre-line;">{pg.summary}</p>}
                    </article>
                  ))}
                </div>
              )}
              {pillarEvents.length > 0 && (
                <p class="meta" style="margin-top: 0.75rem;">
                  <strong>{pillarEvents.length}</strong> event{pillarEvents.length === 1 ? '' : 's'} tagged to this pillar.
                </p>
              )}
            </article>
          );
        })}
      </div>
    </section>
  )}

  {markers.length > 0 && (
    <section>
      <h2>Timeline markers</h2>
      <ul>
        {markers.map((m) => (
          <li>
            <strong>{typeof m.date === 'string' ? m.date : `${m.date?.start ?? ''} → ${m.date?.end ?? ''}`}</strong>
            {' — '}
            {m.description ?? m.id}
          </li>
        ))}
      </ul>
    </section>
  )}

  {actors.length > 0 && (
    <section>
      <h2>Aligned actors</h2>
      <div class="chip-row">
        {actors.map((act) => (
          <a class="actor-chip" href={`/actor/${act.id}`}>{act.canonical_name}</a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2>Events tagged to this doctrine ({events.length})</h2>
    {events.length === 0 ? (
      <p style="color: var(--ctp-subtext0);">
        No events currently tagged here. The doctrine atlas may surface events
        as analysts review unattributed incidents against this doctrine's
        pillars.
      </p>
    ) : (
      <div class="event-list">
        {events.map((ev) => <EventRow event={ev} />)}
      </div>
    )}
  </section>
</Base>

<style>
  .doctrine-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin: 1rem 0 0.5rem;
  }
  .meta {
    color: var(--ctp-subtext0);
    margin: 0 0 0.5rem;
    font-size: 0.9375rem;
  }
  .pillars {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  .pillar {
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    background: var(--ctp-mantle);
  }
  .pillar-id {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-overlay0);
    margin: 0 0 0.5rem;
  }
  .program {
    border-left: 2px solid var(--ctp-surface1);
    padding: 0.25rem 0 0.25rem 0.75rem;
    margin: 0.5rem 0;
  }
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.5rem 0;
  }
  .sector-chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    background: var(--ctp-surface0);
    color: var(--ctp-subtext1);
    padding: 0.125rem 0.4rem;
    border-radius: var(--radius-sm);
  }
  .actor-chip {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--ctp-surface0);
    color: var(--ctp-text);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .actor-chip:hover {
    background: var(--ctp-blue);
    color: var(--ctp-base);
  }
  .status-chip {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.125rem 0.4rem;
    border-radius: var(--radius-sm);
    background: var(--ctp-surface0);
    color: var(--ctp-subtext1);
  }
  .status-superseded { background: var(--ctp-overlay0); color: var(--ctp-base); }
  .status-inferred { background: var(--ctp-yellow); color: var(--ctp-base); }
  .status-historical { background: var(--ctp-surface1); color: var(--ctp-subtext1); }
  ul.genealogy {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
  }
  ul.genealogy li {
    padding: 0.4rem 0.75rem;
    margin: 0.25rem 0;
    background: var(--ctp-mantle);
    border: 1px solid var(--ctp-surface0);
    border-left: 3px solid var(--ctp-mauve);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
  }
  ul.genealogy strong {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-subtext0);
    margin-right: 0.5rem;
  }
  ul.genealogy a { color: var(--ctp-blue); text-decoration: none; }
  ul.genealogy a:hover { text-decoration: underline; }
  .event-list {
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .event-list :global(.event-row:last-child) { border-bottom: none; }
</style>
