---
import Base from '../../layouts/Base.astro';
import AccuracyHeatmap from '../../components/AccuracyHeatmap.astro';
import ReliabilityDiagram from '../../components/ReliabilityDiagram.astro';
import { atlas } from '../../utils/atlas';
import { runLeaveOneOut, runStability } from '../../utils/attribution-eval';
import { calibratedProbs } from '../../utils/calibration';
import { CALIBRATION } from '../../utils/calibration-constants';
import { bootstrapMeanCI, fmtPctCI, fmtNumCI } from '../../utils/eval-stats';

const a = atlas();
const eval_ = runLeaveOneOut();
const stability = runStability(8, 0.1);

function pct(num: number, den: number): string {
  if (den === 0) return 'n/a';
  return `${((num / den) * 100).toFixed(1)}%`;
}
function actorName(id: string): string {
  return a.actors.get(id)?.canonical_name ?? id;
}
const perState = [...eval_.perState.entries()].sort((a, b) => b[1].scored - a[1].scored);
const generatedAt = eval_.generatedAt;

// ─── bootstrap 95% CIs on the headline metrics (n=2000, seeded) ───
const scoredEvents = eval_.events.filter((r) => r.bestRank !== null);
const hit1Vals = scoredEvents.map((r) => (r.hit1 ? 1 : 0));
const hit3Vals = scoredEvents.map((r) => (r.hit3 ? 1 : 0));
const hit5Vals = scoredEvents.map((r) => (r.hit5 ? 1 : 0));
const mrrVals  = scoredEvents.map((r) => (r.bestRank ? 1 / r.bestRank : 0));
const ciHit1 = bootstrapMeanCI(hit1Vals);
const ciHit3 = bootstrapMeanCI(hit3Vals);
const ciHit5 = bootstrapMeanCI(hit5Vals);
const ciMrr  = bootstrapMeanCI(mrrVals);

// ─── reliability-diagram samples ───
// For each scored event, softmax the top-5 logScores → rank-1 prob.
// (We only retain top-5 from the eval, so this approximates rank-1
// probability under the mild assumption that the held-out mass beyond
// rank-5 is small. The post-calibration plot uses the fitted T.)
const samplesUncal: Array<{ predicted: number; correct: boolean }> = [];
const samplesCal: Array<{ predicted: number; correct: boolean }> = [];
// Per-actor calibration: map predicted-actor → samples. Built from the
// post-calibration probabilities so we measure deployable confidence.
const perActorSamples = new Map<string, Array<{ predicted: number; correct: boolean }>>();
for (const r of eval_.events) {
  if (r.top5.length === 0) continue;
  const scores = r.top5.map((c) => c.logScore);
  const probsUncal = calibratedProbs(scores, 1.0);
  const probsCal = calibratedProbs(scores, CALIBRATION.attribution.temperature);
  const top1Actor = r.top5[0].actorId;
  const correct = r.trueActors.includes(top1Actor);
  if (Number.isFinite(probsUncal[0])) samplesUncal.push({ predicted: probsUncal[0], correct });
  if (Number.isFinite(probsCal[0]))   {
    samplesCal.push({ predicted: probsCal[0], correct });
    let bucket = perActorSamples.get(top1Actor);
    if (!bucket) { bucket = []; perActorSamples.set(top1Actor, bucket); }
    bucket.push({ predicted: probsCal[0], correct });
  }
}
// Keep actors with n >= 15 predictions — below that the reliability
// diagram has too few points-per-bin to read.
const perActorRows = [...perActorSamples.entries()]
  .filter(([, samples]) => samples.length >= 15)
  .map(([actorId, samples]) => ({ actorId, samples, n: samples.length }))
  .sort((a, b) => b.n - a.n)
  .slice(0, 8);

// ─── accuracy-heatmap rows ───
const heatmapRows = perState.map(([state, row]) => ({
  state,
  scored: row.scored,
  hit1: row.hit1,
  hit3: row.hit3,
  hit5: row.hit5,
  mrr: row.mrr,
}));
const attributionMetrics = [
  { key: 'hit1', label: 'top-1', kind: 'pct' as const, get: (r: typeof heatmapRows[number]) => r.hit1 },
  { key: 'hit3', label: 'top-3', kind: 'pct' as const, get: (r: typeof heatmapRows[number]) => r.hit3 },
  { key: 'hit5', label: 'top-5', kind: 'pct' as const, get: (r: typeof heatmapRows[number]) => r.hit5 },
  { key: 'mrr',  label: 'MRR',   kind: 'num' as const, get: (r: typeof heatmapRows[number]) => r.mrr },
];
const stateLabel = (s: string) => a.nationStates.get(s)?.short_name ?? a.nationStates.get(s)?.name ?? s.toUpperCase();
---
<Base title="Attribution engine — backtest" wide>
  <p class="kicker">Research</p>
  <h1>Attribution engine — backtest</h1>
  <p class="lede">
    AUSPEX runs a Bayesian Naive-Bayes attribution engine over the
    atlas. Every labeled event is held out, the engine is retrained
    on the remaining corpus, and the engine's ranking is compared to
    the actual public attribution. We publish the score so you can
    decide how much weight to put on the engine.
  </p>
  <p class="meta">Generated {generatedAt} · n={eval_.scored} labeled events scored</p>

  <section>
    <h2>Headline</h2>
    <div class="stat-grid">
      <div class="stat" title={fmtPctCI(ciHit1)}><strong>{pct(eval_.hit1, eval_.scored)}</strong>top-1 hit</div>
      <div class="stat" title={fmtPctCI(ciHit3)}><strong>{pct(eval_.hit3, eval_.scored)}</strong>top-3 hit</div>
      <div class="stat" title={fmtPctCI(ciHit5)}><strong>{pct(eval_.hit5, eval_.scored)}</strong>top-5 hit</div>
      <div class="stat"><strong>{pct(eval_.hit10, eval_.scored)}</strong>top-10 hit</div>
      <div class="stat" title={fmtNumCI(ciMrr)}><strong>{eval_.mrr.toFixed(3)}</strong>MRR</div>
      <div class="stat"><strong>{eval_.scored}</strong>events scored</div>
    </div>
    <div class="ci-band">
      <strong>95% CIs</strong> (non-parametric bootstrap, 2000 iter, seeded):
      top-1 {fmtPctCI(ciHit1)} · top-3 {fmtPctCI(ciHit3)} · top-5 {fmtPctCI(ciHit5)} · MRR {fmtNumCI(ciMrr)}
    </div>
    <p>
      Top-1 hit means the engine's most-likely candidate matched the
      actual public attribution. MRR is the mean reciprocal rank — the
      average of 1/rank across all events; higher is better, 1.0 is
      perfect. CIs are computed by resampling held-out events with
      replacement; the seeded LCG keeps numbers reproducible.
    </p>
  </section>

  <section>
    <h2>Per-state breakdown</h2>
    <p>
      Where the engine works and where it doesn't. The number that
      matters is top-1 — but for high-actor-count states (CN), top-3
      is the more useful metric because the engine is doing real work
      narrowing the candidate set even when it's not nailing the
      single right answer.
    </p>
    <AccuracyHeatmap rows={heatmapRows} metrics={attributionMetrics} labelOf={stateLabel} engineLabel="attribution engine" />
    <p class="reading">
      <strong>Reading.</strong> US scores high because its actor pool
      is small and operationally distinct. CN scores low at top-1
      because APT41 / APT31 / APT10 / APT40 all target similar
      MIC2025-aligned sectors with similar vectors — the feature
      space the engine has doesn't discriminate them well. That's a
      <em>data-richness</em> finding: closing the CN top-1 gap
      requires per-actor TTP / malware-family / tradecraft features,
      not more events.
    </p>
  </section>

  <section>
    <h2>Calibration</h2>
    <p>
      A model that says "80% confident" should be right 80% of the
      time. Reliability diagrams check this directly — points above
      the diagonal mean <em>under</em>-confidence; points below mean
      <em>over</em>-confidence. ECE (expected calibration error) is
      the n-weighted average gap; MCE is the worst single bin.
      Temperature scaling (T={CALIBRATION.attribution.temperature.toFixed(1)})
      pulls overconfident predictions back toward the identity line
      without re-ranking — accuracy is unchanged, the probabilities
      become honest.
    </p>
    <div class="cal-grid">
      <ReliabilityDiagram samples={samplesUncal} title="Uncalibrated (raw softmax)" />
      <ReliabilityDiagram samples={samplesCal}   title={`Calibrated (T=${CALIBRATION.attribution.temperature.toFixed(1)})`} />
    </div>
    <p class="reading" style="margin-top: 0.5rem;">
      <strong>Method.</strong> Each sample is one held-out event:
      X = post-softmax probability assigned by the engine to its
      rank-1 candidate, Y = whether that rank-1 candidate matched
      the actual public attribution. Softmax is computed over the
      retained top-5 log-scores. Bins are equal-width (10 of them).
      Calibrated improvement vs uncalibrated NLL on the full corpus:{' '}
      <strong>{CALIBRATION.attribution.improvementPct.toFixed(1)}%</strong>
      (n={CALIBRATION.attribution.sampleSize}).
    </p>
  </section>

  {perActorRows.length > 0 && (
    <section>
      <h2>Per-actor calibration</h2>
      <p>
        The engine-wide reliability diagram above can mask per-actor
        miscalibration — an engine can be well-calibrated on average
        while being systematically overconfident on one cluster and
        underconfident on another. Below: reliability diagrams for
        the top-{perActorRows.length} actors by prediction count
        (n ≥ 15). Same identity diagonal, same 10-bin protocol, same
        T = {CALIBRATION.attribution.temperature.toFixed(1)}.
        Per-actor ECE quantifies the cluster-specific calibration
        gap; tight clusters (≤ 0.05) indicate analyst-deployable
        confidence numbers for that actor; wider gaps mean the
        engine's probability for that actor should be treated as
        an ordinal hint, not a calibrated likelihood.
      </p>
      <div class="cal-grid">
        {perActorRows.map((row) => {
          const actor = a.actors.get(row.actorId);
          const label = actor?.canonical_name ?? row.actorId;
          return (
            <ReliabilityDiagram
              samples={row.samples}
              title={`${label} · n=${row.n}`}
              size={260}
              bins={6}
            />
          );
        })}
      </div>
      <p class="reading" style="margin-top: 0.5rem;">
        <strong>Reading.</strong> Six bins instead of ten because
        per-actor sample sizes don't support 10-bin resolution
        without empty bins. Actors are shown in descending order of
        prediction count (the engine predicted them most often).
        Cluster identification by inspection: tight points on the
        diagonal = good calibration for that cluster; consistent
        gap above the diagonal = the engine is systematically
        under-confident for this cluster (probabilities should be
        bumped up); gap below = systematic over-confidence.
      </p>
    </section>
  )}

  <section>
    <h2>Top confusion pairs</h2>
    <p>
      When the engine's rank-1 prediction was wrong, what did it
      predict instead of the truth?
    </p>
    <table class="conf-table">
      <thead>
        <tr><th>predicted (engine top-1)</th><th>actual</th><th>×</th></tr>
      </thead>
      <tbody>
        {eval_.confusion.slice(0, 12).map((c) => (
          <tr>
            <td><a href={`/actor/${c.predicted}`}>{actorName(c.predicted)}</a></td>
            <td><a href={`/actor/${c.actual}`}>{actorName(c.actual)}</a></td>
            <td><strong>{c.count}</strong></td>
          </tr>
        ))}
      </tbody>
    </table>
    <p class="reading">
      <strong>Reading.</strong> Several rows here aren't really
      <em>errors</em> — Lazarus ↔ APT38 is the same umbrella; APT32 ↔
      APT28 is a real shared-doctrine-signature finding (both target
      diaspora / ASEAN governments). Treat confusion as a structural
      cluster-similarity map, not a list of failures.
    </p>
  </section>

  <section>
    <h2>Worst predictions</h2>
    <p>The events where the true actor ranked furthest from the top.</p>
    <table class="worst-table">
      <thead>
        <tr><th>rank</th><th>date</th><th>event</th><th>true</th><th>engine top-1</th></tr>
      </thead>
      <tbody>
        {eval_.worst.slice(0, 12).map((w) => (
          <tr>
            <td>{w.bestRank}</td>
            <td>{w.startDate ?? '????'}</td>
            <td><a href={`/event/${w.eventId}`}>{w.eventName}</a></td>
            <td><a href={`/actor/${w.trueActors[0]}`}>{actorName(w.trueActors[0] ?? '')}</a></td>
            <td>{w.top5[0] && <a href={`/actor/${w.top5[0].actorId}`}>{actorName(w.top5[0].actorId)}</a>}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <section>
    <h2>Monte Carlo stability</h2>
    <p>
      How robust are the engine's top picks if we resample the
      training corpus? We drop {Math.round(stability.dropFraction * 100)}%
      of events at random, retrain, and check whether the rank-1 pick
      stays the same.
    </p>
    <div class="stat-grid">
      <div class="stat"><strong>{(stability.rank1Stability * 100).toFixed(1)}%</strong>rank-1 stable</div>
      <div class="stat"><strong>{(stability.top3StabilityJaccard * 100).toFixed(1)}%</strong>top-3 stable (J≥.5)</div>
      <div class="stat"><strong>{stability.n}</strong>resamples</div>
    </div>
    <p class="reading">
      A low rank-1 stability number means small corpus changes flip
      the engine's preferred answer often — i.e., the engine is
      fitting noise. A high number means the model is robust to
      reasonable label / corpus uncertainty.
    </p>
  </section>

  <section>
    <h2>What this means and what's next</h2>
    <p>
      The engine is a useful narrowing tool, not an oracle. At top-3
      it eliminates most candidates from consideration; at top-1 it is
      right about 57% of the time. That is better than chance on a
      133-actor label space by a factor of 75+, but it isn't good enough
      to attribute live events without analyst review.
    </p>
    <p>Concrete next steps in v0.1:</p>
    <ul>
      <li>
        <strong>TTP / malware-family features.</strong> The CN
        confusion is the loudest signal that we need per-actor
        tradecraft features. Closing this gap is the single biggest
        engine improvement available.
      </li>
      <li>
        <strong>Service-level rollup as a fallback.</strong> When the
        engine can't pick between APT41 / APT31 it can still
        confidently say "CN MSS." Expose that as an explicit lower-
        resolution prediction.
      </li>
      <li>
        <strong>Doctrine-prediction layer.</strong> Independently of
        actor, predict the doctrine pillar — that's the engine output
        most directly useful for analysts asking "why."
      </li>
      <li>
        <strong>Backtest by year, not by event.</strong> Hold out a
        whole year and predict it from prior years only. That's the
        right shape for the prediction engine to come.
      </li>
    </ul>
    <p>
      Methodology and the engine source live in the repo —
      <code>src/utils/attribution.ts</code> and
      <code>src/utils/attribution-eval.ts</code>. Engine output for
      this run: <a href="/api/attribution-eval.json">JSON</a>.
    </p>
  </section>
</Base>

<style>
  .meta { color: var(--ctp-subtext0); font-size: 0.9375rem; margin: 0 0 1.5rem; }
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    margin: 1rem 0 1.5rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.75rem 1rem;
    background: var(--ctp-mantle);
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-subtext1);
  }
  .stat strong {
    font-size: 1.5rem;
    color: var(--ctp-text);
    font-weight: 600;
  }
  table { border-collapse: collapse; width: 100%; font-size: 0.875rem; margin: 0.75rem 0 1rem; }
  th, td { text-align: left; padding: 0.375rem 0.625rem; border-bottom: 1px solid var(--ctp-surface0); vertical-align: top; }
  th { font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--ctp-subtext0); }
  td { font-family: var(--font-mono); font-size: 0.8125rem; }
  td a { color: var(--ctp-text); }
  td a:hover { color: var(--ctp-blue); }
  .state-table td:first-child code, .state-table td:nth-child(2) { font-weight: 600; }
  .worst-table td:first-child { font-weight: 700; color: var(--ctp-peach); }
  .reading {
    background: var(--ctp-mantle);
    border-left: 3px solid var(--ctp-blue);
    padding: 0.625rem 0.875rem;
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    margin: 0.75rem 0;
  }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1rem;
    margin: 0.75rem 0;
  }
  .ci-band {
    margin: 0.5rem 0 0.75rem;
    padding: 0.5rem 0.75rem;
    background: var(--ctp-mantle);
    border-left: 3px solid var(--ctp-overlay0);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-subtext1);
  }
  .ci-band strong { color: var(--ctp-text); }
</style>
