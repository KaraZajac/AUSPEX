---
import Base from '../layouts/Base.astro';
import FlagChip from '../components/FlagChip.astro';
import { atlas } from '../utils/atlas';

const a = atlas();
const allActors = [...a.actors.values()];
function actorsByIdPrefix(prefix: string) {
  return allActors.filter((act) => act.id.startsWith(prefix + '/'));
}
const stateRows = [...a.nationStates.keys()]
  .sort()
  .map((s) => ({ id: s, label: a.nationStates.get(s)?.name ?? s.toUpperCase(), actors: actorsByIdPrefix(s) }))
  .filter((r) => r.actors.length > 0);
const criminalActors = actorsByIdPrefix('criminal');
const byState = criminalActors.length > 0
  ? [...stateRows, { id: 'criminal', label: 'Criminal actors (non-state)', actors: criminalActors }]
  : stateRows;
---
<Base title="Actors" wide>
  <p class="kicker">Atlas</p>
  <h1>Actors</h1>
  <p class="lede">
    Named cyber units and APT groups, grouped by primary attribution.
    Vendor naming reconciliation lives on each actor page (the seven-name
    problem — Mandiant's APT##, CrowdStrike's animal, Microsoft's weather
    name, Kaspersky's name, MITRE's G####).
  </p>

  {byState.map(({ id, label, actors }) => (
    <section>
      <div class="state-head">
        {id !== 'criminal' && <FlagChip state={id} />}
        <h2 style="margin:0;">{label}</h2>
      </div>
      <div class="actor-list">
        {actors.sort((x, y) => x.canonical_name.localeCompare(y.canonical_name)).map((act) => {
          const evCount = a.eventsForActor(act.id).length;
          return (
            <a class="actor-row" href={`/actor/${act.id}`}>
              <span class="actor-name">{act.canonical_name}</span>
              <span class="actor-id">{act.id}</span>
              <span class="event-count">{evCount} event{evCount === 1 ? '' : 's'}</span>
            </a>
          );
        })}
      </div>
    </section>
  ))}
</Base>

<style>
  .state-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 2rem 0 1rem;
  }
  .actor-list {
    border: 1px solid var(--ctp-surface0);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .actor-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.875rem;
    border-bottom: 1px solid var(--ctp-surface0);
    text-decoration: none;
    color: var(--ctp-text);
  }
  .actor-row:last-child { border-bottom: none; }
  .actor-row:hover { background: var(--ctp-mantle); }
  .actor-name {
    font-weight: 500;
  }
  .actor-id {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-overlay0);
  }
  .event-count {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ctp-subtext0);
  }
</style>
