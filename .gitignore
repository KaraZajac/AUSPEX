# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# editor
.vscode/
.idea/
*.swp
*.swo

# node / Astro (defensive — site/.gitignore handles most)
**/node_modules/
**/dist/
**/.astro/
**/.cache/

# env / secrets
.env
.env.*
*.key
*.pem
credentials.json
secrets.json

# logs / temp
*.log
*.tmp
/tmp/

# build artifacts
*.tsbuildinfo
staging/
audit/audit-report.json
release/

# raw source snapshots (local archive; copyright — not redistributed)
atlas/sources/raw/

# Python bytecode
__pycache__/
*.pyc

# stray repo-root curl artifacts from census batches (agents that used a relative scratchpad/ path); real snapshots live in atlas/sources/raw/
scratchpad/
.venv/
